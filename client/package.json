    "@tarojs/plugin-framework-react": "^4.1.11",
    "@tarojs/plugin-platform-weapp": "4.1.11",
    "@tarojs/react": "4.1.11",
    "@tarojs/runtime": "4.1.11",
    "@tarojs/shared": "4.1.11",
    "@tarojs/taro": "4.1.11",
    "dayjs": "^1.11.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "taro-ui": "^3.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@tarojs/cli": "4.1.11",
    "@tarojs/webpack5-runner": "4.1.11",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.0",
    "babel-preset-taro": "4.1.11",
    "less": "^4.6.4",
    "less-loader": "^12.3.2",
    "prettier": "^3.8.1",
    "sass": "^1.80.0",
    "typescript": "^5.6.0",
    "webpack": "^5.90.0"
