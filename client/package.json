    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,scss,css}\""
  },
  "dependencies": {
    "@babel/preset-react": "^7.28.5",
    "@babel/runtime": "^7.24.0",
    "@tarojs/components": "4.1.11",
