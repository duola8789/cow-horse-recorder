{
  "name": "cow-horse-recorder-root",
  "version": "1.1.3",
  "private": true,
  "description": "牛马工时记录器",
  "scripts": {
    "postinstall": "npm run install:all",
    "install:all": "npm run install:client && npm run install:cloud",
    "install:client": "cd client && npm install",
    "install:cloud": "node scripts/install-cloud.js",
    "dev": "cd client && npm run dev:weapp",
    "dev:cloud": "node scripts/watch-cloud.js",
    "dev:all": "npm run build:cloud && npm run dev & npm run dev:cloud",
    "build": "cd client && npm run build:weapp",
    "build:cloud": "node scripts/build-cloud.js",
    "build:all": "npm run build:cloud && npm run build",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.12.0",
    "@eslint-react/eslint-plugin": "^1.53.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  }
}
